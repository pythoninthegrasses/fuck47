{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "bash": {
      "*": "allow",
      // Destructive file operations
      "rm -rf /*": "deny",
      "rm -rf /": "deny",
      "rm *": "ask",
      // Privilege escalation
      "sudo *": "ask",
      // Disk/filesystem destruction (Linux)
      "dd *": "deny",
      "mkfs *": "deny",
      "fdisk *": "deny",
      "parted *": "deny",
      // Disk/filesystem destruction (macOS/BSD)
      "diskutil eraseDisk*": "deny",
      "diskutil eraseVolume*": "deny",
      "diskutil partitionDisk*": "deny",
      "diskutil apfs deleteContainer*": "deny",
      "diskutil *": "ask",
      "newfs*": "deny",
      "mount *": "ask",
      "umount *": "ask",
      // System power
      "shutdown *": "deny",
      "reboot *": "deny",
      "halt *": "deny",
      // macOS system configuration
      "nvram *": "deny",
      "bless *": "deny",
      "csrutil *": "deny",
      "systemsetup *": "deny",
      "launchctl *": "ask",
      "networksetup *": "ask",
      "scutil *": "ask",
      "dscl *": "ask",
      "pmset *": "ask",
      "tmutil delete*": "deny",
      "tmutil *": "ask",
      // Git history destruction
      "git push --force*": "ask",
      "git reset --hard*": "ask",
      // Git branch switching (potential uncommitted work loss)
      "git checkout *": "ask",
      "git switch *": "ask",
      // Process/system disruption
      "killall *": "ask",
      "pkill *": "ask",
      // Network exfiltration footguns
      "curl * | *sh*": "deny",
      "wget * | *sh*": "deny"
    }
  }
}
